{
  "expo": {
    "name": "To The Pub",
    "slug": "to-the-pub-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.tothepub.tothepubapp",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tothepub.tothepubapp"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "To The Pub uses your location to find bars and events near you."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "to-the-pub"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a0125005-6e29-4982-a085-9910609100a2"
      }
    }
  }
}
